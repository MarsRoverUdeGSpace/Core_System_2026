############################
# OS / editor junk
############################

# macOS / Windows
.DS_Store
Thumbs.db

# Vim / editors
*~
*.swp
*.swo
*.tmp

############################
# Python / MicroPython
############################

__pycache__/
*.py[cod]
*.pyo
*.pyd

.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Virtualenvs
.venv/
venv/
env/
.env
.env.*

############################
# ROS 2 / colcon workspace
############################

# Standard colcon/ament outputs
build/
install/
log/

############################
# C / C++ / CMake / Make
############################

# Local CMake build dirs (CLion, etc.)
cmake-build-*/
CMakeFiles/
CMakeCache.txt
CTestTestfile.cmake
cmake_install.cmake

# Generic build artifacts
*.o
*.obj
*.a
*.lib
*.dll
*.so
*.dylib
*.exe

############################
# PlatformIO / Arduino / MCU
############################

# PlatformIO
.pio/
.pioenvs/
.piolibdeps/

# Arduino / generic firmware binaries
*.elf
*.hex
*.bin

# ESP-IDF / other firmware builds (covered by build/)
# (Per-project 'build/' dirs will also be ignored by the build/ rule above)

############################
# IDE / tooling
############################

# VS Code
.vscode/
*.code-workspace

# JetBrains / CLion
.idea/

# Language server caches
.ccls-cache/
.clangd/

############################
# KiCad
############################

# KiCad 6/7+ backup directories (e.g. MCU-backups/)
*-backups/

# Per-project footprint cache
fp-info-cache

# KiCad project-local settings (non-essential)
*.kicad_prl

# Optional: KiCad autobackups
*.kicad_sch-bak
*.kicad_pcb-bak

############################
# Misc logs / dumps
############################

*.log
src/micro-ROS-Agent/
src/micro_ros_msgs/
