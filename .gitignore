# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Archived Backups (KiCad 6.0)
**/*-backups/*.zip

# Local project settings
*.kicad_prl

# ── PlatformIO / Arduino build artefacts ─────────────────────────────
.pio/
.pioenvs/
.piolibdeps/
.vscode/
*.elf
*.hex
*.bin
# PlatformIO unit-test output
.piotest/
# Serial monitor logs
*.log
# Arduino CLI build cache
build/
# Core dumps (Espressif)
core*
# Cloud IDE settings (optional)
.clangd/
.idea/

# ── MicroPython bytecode & CPython caches ────────────────────────────
*.mpy
__pycache__/
*.pyc
*.pyo

# ── Virtual environments ─────────────────────────────────────────────
.venv/
venv/
env/

# ── Test & type-check caches ─────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Editor/IDE noise ─────────────────────────────────────────────────
.vscode/
.idea/
.ropeproject/

# ── Firmware / deployment artefacts (ESP32/RP2040/etc.) ─────────────
firmware*.bin
*.bin
*.elf
*.map
*.uf2

# ── Tool configs & logs (local) ──────────────────────────────────────
.mpremote.json
rshell.history
ampy.log
*.log

# ── Optional: keep real secrets local (use template in Git) ─────────
# secrets.py
